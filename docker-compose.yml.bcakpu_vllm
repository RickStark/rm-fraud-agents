version: '3.8'

services:
  zookeeper:
    image: confluentinc/cp-zookeeper:7.5.0
    container_name: zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000
    ports:
      - "2181:2181"
    networks:
      - fraud-network
    healthcheck:
      test: ["CMD", "nc", "-z", "localhost", "2181"]
      interval: 10s
      timeout: 5s
      retries: 5

  kafka:
    image: confluentinc/cp-kafka:7.5.0
    container_name: kafka
    depends_on:
      zookeeper:
        condition: service_healthy
    ports:
      - "9092:9092"
      - "9093:9093"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:9093
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: "true"
    networks:
      - fraud-network
    healthcheck:
      test: ["CMD-SHELL", "nc -z localhost 9092"]
      interval: 10s
      timeout: 10s
      retries: 5

  kafka-ui:
    image: provectuslabs/kafka-ui:latest
    container_name: kafka-ui
    depends_on:
      - kafka
    ports:
      - "8080:8080"
    environment:
      KAFKA_CLUSTERS_0_NAME: local
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:9092
      KAFKA_CLUSTERS_0_ZOOKEEPER: zookeeper:2181
    networks:
      - fraud-network

  postgres:
    image: postgres:15-alpine
    container_name: postgres-fraud
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: fraud_detection
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./init_db.sql:/docker-entrypoint-initdb.d/init_db.sql
    networks:
      - fraud-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  adminer:
    image: adminer:latest
    container_name: adminer
    depends_on:
      - postgres
    ports:
      - "8081:8080"
    networks:
      - fraud-network

  # ==========================================
  # vLLM - Backend LLM rápido con GPU
  # ==========================================
  vllm:
    image: vllm/vllm-openai:latest
    container_name: vllm_server
    ports:
      - "8000:8000"
    volumes:
      - vllm_models:/root/.cache/huggingface
    networks:
      - fraud-network
    # GPU NVIDIA
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
    # Configuración optimizada para GTX 5060 (8GB)
    command: >
      --model microsoft/Phi-3-mini-4k-instruct
      --dtype float16
      --max-model-len 50
      --gpu-memory-utilization 0.80
      --max-num-seqs 1
    environment:
      - VLLM_USE_V1=0
      - VLLM_ATTENTION_BACKEND=XFORMERS
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 240s
    restart: unless-stopped

  # ==========================================
  # FRAUD AGENTS - CrewAI con vLLM backend
  # ==========================================
  fraud-agents:
    build: .
    container_name: crewai_fraud_detector
    depends_on:
      kafka:
        condition: service_healthy
      postgres:
        condition: service_healthy
      vllm:
        condition: service_healthy
    environment:
      # vLLM configuration (CrewAI lo usa via API OpenAI)
      - VLLM_BASE_URL=http://vllm:8000/v1
      - VLLM_MODEL=microsoft/Phi-3-mini-4k-instruct
      - LITELLM_DROP_SYSTEM_MESSAGES=true
      # Kafka
      - KAFKA_BROKER=kafka:9092
      - KAFKA_TOPIC=transactions
      - KAFKA_GROUP_ID=fraud-detection-group
      # PostgreSQL
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_NAME=fraud_detection
      - DB_USER=postgres
      - DB_PASSWORD=postgres
    volumes:
      - .:/app
    networks:
      - fraud-network
    command: python src/fraud_detection_crewai_vllm.py
    restart: unless-stopped
  # ==========================================
  # TRANSACTION PRODUCER
  # ==========================================
  transaction-producer:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: transaction-producer
    depends_on:
      kafka:
        condition: service_healthy
      postgres:
        condition: service_healthy
    environment:
      - KAFKA_BROKER=kafka:9092
      - KAFKA_TOPIC=transactions
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_NAME=fraud_detection
      - DB_USER=postgres
      - DB_PASSWORD=postgres
    volumes:
      - .:/app
    networks:
      - fraud-network
    command: python transaction_producer.py

networks:
  fraud-network:
    driver: bridge

volumes:
  vllm_models:
  postgres-data:
