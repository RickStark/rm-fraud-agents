version: '3.8'

services:
  # ==========================================
  # ZOOKEEPER - Requerido por Kafka
  # ==========================================
  zookeeper:
    image: confluentinc/cp-zookeeper:7.5.0
    container_name: zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000
    ports:
      - "2181:2181"
    networks:
      - fraud-network
    healthcheck:
      test: ["CMD", "nc", "-z", "localhost", "2181"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ==========================================
  # KAFKA - Sistema de mensajería
  # ==========================================
  kafka:
    image: confluentinc/cp-kafka:7.5.0
    container_name: kafka
    depends_on:
      zookeeper:
        condition: service_healthy
    ports:
      - "9092:9092"
      - "9093:9093"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:9093
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: "true"
    networks:
      - fraud-network
    healthcheck:
      test: ["CMD", "kafka-broker-api-versions", "--bootstrap-server", "localhost:9092"]
      interval: 10s
      timeout: 10s
      retries: 5

  # ==========================================
  # KAFKA UI - Interfaz web para Kafka
  # ==========================================
  kafka-ui:
    image: provectuslabs/kafka-ui:latest
    container_name: kafka-ui
    depends_on:
      - kafka
    ports:
      - "8080:8080"
    environment:
      KAFKA_CLUSTERS_0_NAME: local
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:9092
      KAFKA_CLUSTERS_0_ZOOKEEPER: zookeeper:2181
    networks:
      - fraud-network

  # ==========================================
  # POSTGRESQL - Base de datos
  # ==========================================
  postgres:
    image: postgres:15-alpine
    container_name: postgres-fraud
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: fraud_detection
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./init_db.sql:/docker-entrypoint-initdb.d/init_db.sql
    networks:
      - fraud-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ==========================================
  # ADMINER - Interfaz web para PostgreSQL
  # ==========================================
  adminer:
    image: adminer:latest
    container_name: adminer
    depends_on:
      - postgres
    ports:
      - "8081:8080"
    networks:
      - fraud-network

  # ==========================================
  # OLLAMA - Motor del LLM Local (YA EXISTENTE)
  # ==========================================
  ollama:
    image: ollama/ollama:latest
    container_name: local_llm_server
    ports:
      - "11434:11434"
    volumes:
      - ollama_models:/root/.ollama
    networks:
      - fraud-network
    restart: always
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:11434/api/tags"]
      interval: 30s
      timeout: 10s
      retries: 3

  # ==========================================
  # FRAUD AGENTS - Tu sistema Multi-Agente (ACTUALIZADO)
  # ==========================================
  fraud-agents:
    build: .
    container_name: crewai_fraud_detector
    depends_on:
      kafka:
        condition: service_healthy
      postgres:
        condition: service_healthy
      ollama:
        condition: service_started
    environment:
      # Configuración de Ollama
      - OLLAMA_BASE_URL=http://ollama:11434
      - OPENAI_API_KEY=NA
      # Configuración de Kafka
      - KAFKA_BROKER=kafka:9092
      - KAFKA_TOPIC=transactions
      - KAFKA_GROUP_ID=fraud-detection-group
      # Configuración de PostgreSQL
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_NAME=fraud_detection
      - DB_USER=postgres
      - DB_PASSWORD=postgres
    volumes:
      - .:/app
    networks:
      - fraud-network
    # Ahora ejecuta el script de detección de fraude
    command: python src/main.py
    restart: unless-stopped

  # ==========================================
  # TRANSACTION PRODUCER - Simulador de transacciones (NUEVO)
  # ==========================================
  transaction-producer:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: transaction-producer
    depends_on:
      kafka:
        condition: service_healthy
      postgres:
        condition: service_healthy
    environment:
      - KAFKA_BROKER=kafka:9092
      - KAFKA_TOPIC=transactions
      - DB_HOST=postgres
      - DB_PORT=5432
      - DB_NAME=fraud_detection
      - DB_USER=postgres
      - DB_PASSWORD=postgres
    volumes:
      - .:/app
    networks:
      - fraud-network
    command: python transaction_producer.py

networks:
  fraud-network:
    driver: bridge

volumes:
  ollama_models:
  postgres-data: